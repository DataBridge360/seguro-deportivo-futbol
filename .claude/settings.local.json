      "Bash(npm install:*)",
      "Bash(powershell -Command \"Rename-Item -Path ''\\(dashboard\\)'' -NewName ''dashboard''\")",
      "Bash(powershell -Command \"if \\(Test-Path ''dashboard''\\) { Remove-Item -Recurse -Force ''dashboard'' }; Rename-Item -Path ''\\(dashboard\\)'' -NewName ''dashboard''\")",
      "Bash(powershell -Command \"Rename-Item -Path ''\\(dashboard\\)'' -NewName ''dashboard'' -Force\")",
      "Bash(npm run lint)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git checkout:*)",
      "Bash(git merge:*)",
      "Bash(git stash:*)",
      "Bash(git branch:*)"
    ]
  }
}
